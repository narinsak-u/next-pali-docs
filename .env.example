# ──────────────────────────────────────────
# Pali Docs — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Pinecone (Vector Database) ────────────
# Required for RAG chat feature.
# Sign up: https://www.pinecone.io
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
# Optional: scopes queries to a namespace within the index
PINECONE_NAMESPACE=

# ── OpenRouter (LLM Gateway) ──────────────
# Required for AI chat, quiz generation, and follow-up suggestions.
# Sign up: https://openrouter.ai
# Set either PROVIDER_API_KEY or OPENAI_API_KEY (both map to same value).
PROVIDER_API_KEY=
# Optional: override the default LLM model (default: google/gemma-4-31b-it:free)
LLM_MODEL=

# ── Algolia (Full-Text Search) ────────────
# Required for the documentation search UI and indexing script.
# Sign up: https://www.algolia.com
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=
# Admin API key (server-side only, used by npm run index)
NEXT_PUBLIC_ALGOLIA_ADMIN_API_KEY=
# Optional: for Algolia Assistant / AI search features
NEXT_PUBLIC_ALGOLIA_ASSISTANT_ID=
